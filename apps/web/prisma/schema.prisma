generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  projects  Project[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id         String        @id @default(cuid())
  name       String
  slug       String        @unique
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeys    ApiKey[]
  schemas    EventSchema[]
  dashboards Dashboard[]
  events     Event[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([userId])
}

model ApiKey {
  id         String    @id @default(cuid())
  name       String
  keyHash    String    @unique
  keyPrefix  String
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([keyHash])
  @@index([projectId])
}

model EventSchema {
  id        String   @id @default(cuid())
  name      String
  version   Int      @default(1)
  fields    Json
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

model Event {
  id         String   @id @default(cuid())
  eventName  String
  properties Json
  timestamp  DateTime
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@index([projectId, eventName, timestamp])
  @@index([projectId, timestamp])
}

model Dashboard {
  id        String   @id @default(cuid())
  name      String
  widgets   Json
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}
